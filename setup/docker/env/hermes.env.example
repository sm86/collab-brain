# Copy this file to setup/docker/env/hermes.env and fill in the values you need.
# The real hermes.env file is gitignored.

# Common provider API keys. Uncomment/use what applies to your Hermes model setup.
# NOUS_API_KEY=
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=
# ANTHROPIC_API_KEY=
# HF_TOKEN=
# NOVITA_API_KEY=
# NVIDIA_API_KEY=
# MOONSHOT_API_KEY=
# MINIMAX_API_KEY=

# Optional: override Hermes data directory inside the container.
HERMES_HOME=/root/.hermes

# Seed SOUL.md, memories/USER.md, memories/MEMORY.md, and config.yaml from the
# image-bundled mock Garry profile on first start.
# Existing files are never overwritten.
HERMES_BOOTSTRAP_PROFILE=true
HERMES_PROFILE_TEMPLATE_DIR=/opt/hermes/mock-garry-profile

# Default Hermes model/provider to persist into /root/.hermes/config.yaml.
HERMES_DEFAULT_PROVIDER=openrouter
HERMES_DEFAULT_MODEL=moonshotai/kimi-k2.6

# GBrain local PGLite brain data lives under $GBRAIN_HOME/.gbrain.
# /root is persisted by the hermes-home Docker volume.
GBRAIN_HOME=/root
GBRAIN_INIT_ON_START=true
# Pick one after reviewing the cost matrix: conservative, balanced, tokenmax.
GBRAIN_SEARCH_MODE=conservative

# Import bundled Garry mock data into the default GBrain once on first start.
GBRAIN_IMPORT_MOCK_GARRY_ON_START=true
GBRAIN_MOCK_GARRY_SOURCE=/opt/hermes/mockdata/garry

# Optional: run a command when the container starts.
# For a persistent idle container, leave this blank.
# For gateway mode, you might use: hermes gateway start
HERMES_COMMAND=
