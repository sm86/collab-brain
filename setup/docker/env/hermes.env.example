# Copy this file to setup/docker/env/hermes.env and fill in the values you need.
# The real hermes.env file is gitignored.

# Common provider API keys. Uncomment/use what applies to your Hermes model setup.
# NOUS_API_KEY=
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=
# ANTHROPIC_API_KEY=
# HF_TOKEN=
# NOVITA_API_KEY=
# NVIDIA_API_KEY=
# MOONSHOT_API_KEY=
# MINIMAX_API_KEY=

# Optional: override Hermes data directory inside the container.
HERMES_HOME=/root/.hermes

# Seed SOUL.md, memories/USER.md, memories/MEMORY.md, and config.yaml from each
# service's image-bundled partner profile on first start.
# Existing files are never overwritten.
HERMES_BOOTSTRAP_PROFILE=true

# Default Hermes model/provider to persist into /root/.hermes/config.yaml.
HERMES_DEFAULT_PROVIDER=openrouter
HERMES_DEFAULT_MODEL=moonshotai/kimi-k2.6

# GBrain local PGLite brain data lives under $GBRAIN_HOME/.gbrain.
# /root is persisted by each partner service's Docker volume.
GBRAIN_HOME=/root
GBRAIN_INIT_ON_START=true
# Pick one after reviewing the cost matrix: conservative, balanced, tokenmax.
GBRAIN_SEARCH_MODE=conservative

# Import each service's bundled mock data into its GBrain once on first start.
# Partner-specific source paths and markers live in docker-compose.yml.
GBRAIN_MOCK_IMPORT_ON_START=true

# Optional A2A company-info endpoint. This is unauthenticated and HTTP-only;
# do not expose it to a network you do not fully control.
A2A_ENABLED=false
A2A_PORT=8080
# Keep internal port 8080 for every partner. Compose maps host ports 8081-8083.
# Use 0.0.0.0 to reach healthz from the host when A2A is enabled.
A2A_BIND=0.0.0.0
A2A_HERMES_TIMEOUT=90
A2A_GBRAIN_TIMEOUT=15

# Optional: run a command when the container starts.
# For a persistent idle container, leave this blank.
# For gateway mode, you might use: hermes gateway start
HERMES_COMMAND=
